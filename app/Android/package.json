{
  "name": "nldocs-android",
  "version": "1.0.0",
  "description": "NLDocs Android App",
  "scripts": {
    "sync": "npx cap sync android",
    "open": "npx cap open android",
    "build:web": "cd ../../frontend && npm run build",
    "copy": "npm run build:web && npx cap copy android",
    "build:apk": "npm run copy && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  }
}
